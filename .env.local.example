# Copiaza acest fisier ca .env.local pentru development local
# Pe Vercel, seteaza aceste variabile in Dashboard > Settings > Environment Variables

# Google Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Anthropic / Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail sender
SENDER_EMAIL=youremail@gmail.com
SENDER_APP_PASSWORD=xxxx xxxx xxxx xxxx
SENDER_NAME=Prenume Nume

# Branding (optional - can also be set in UI Settings)
YOUR_WEBSITE=https://websitultau.ro
YOUR_PORTFOLIO_URL=https://portofoliu.websitultau.ro
