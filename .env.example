# === Google Places API ===
# Obtine de la: https://console.cloud.google.com/
# Activeaza: Places API (New) sau Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# === Anthropic / Claude API ===
# Obtine de la: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Email Sender (Gmail recomandat) ===
# Foloseste App Password, nu parola Gmail!
# Activeaza: https://myaccount.google.com/apppasswords
SENDER_EMAIL=youremail@gmail.com
SENDER_APP_PASSWORD=your_gmail_app_password_here
SENDER_NAME=Prenume Nume

# === Setari campanie ===
# Orasele tinta separate prin virgula
TARGET_CITIES=Cluj-Napoca,Brasov,Sibiu,Targu Mures,Alba Iulia,Bistrita,Deva,Sighisoara,Oradea,Timisoara

# Categoriile de afaceri tinta (Google Places types)
TARGET_CATEGORIES=restaurant,dentist,beauty_salon,car_repair,plumber,electrician,lawyer,accounting,lodging,hair_care

# Numarul maxim de emailuri trimise per zi
MAX_EMAILS_PER_DAY=150

# Delay intre emailuri (secunde) - evita spam filters
EMAIL_DELAY_SECONDS=45

# Limba emailului: ro (romana) sau en (engleza)
EMAIL_LANGUAGE=ro

# Website-ul tau / portofoliu pentru credibilitate
YOUR_WEBSITE=https://websitultau.ro
YOUR_PORTFOLIO_URL=https://portofoliu.websitultau.ro
